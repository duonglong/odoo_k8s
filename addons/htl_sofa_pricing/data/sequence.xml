<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Quote Numbers -->
        <record id="seq_sofa_price_quote" model="ir.sequence">
            <field name="name">Sofa Price Quote</field>
            <field name="code">sofa.price.quote</field>
            <field name="prefix">Q-%(year)s-</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>
    </data>
</odoo>
