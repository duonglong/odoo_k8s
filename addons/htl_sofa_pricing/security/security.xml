<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Security Groups -->
    <record id="group_sofa_pricing_user" model="res.groups">
        <field name="name">Sofa Pricing User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_sofa_pricing_manager" model="res.groups">
        <field name="name">Sofa Pricing Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_sofa_pricing_user'))]"/>
    </record>

    <!-- Record Rules -->
    <record id="sofa_price_quote_user_rule" model="ir.rule">
        <field name="name">Sofa Price Quote: User can see own quotes</field>
        <field name="model_id" ref="model_sofa_price_quote"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_sofa_pricing_user'))]"/>
    </record>

    <record id="sofa_price_quote_manager_rule" model="ir.rule">
        <field name="name">Sofa Price Quote: Manager can see all quotes</field>
        <field name="model_id" ref="model_sofa_price_quote"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_sofa_pricing_manager'))]"/>
    </record>
</odoo>
