<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Margin Tree View -->
    <record id="view_sofa_margin_tree" model="ir.ui.view">
        <field name="name">sofa.margin.tree</field>
        <field name="model">sofa.margin</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="series_id"/>
                <field name="article_group"/>
                <field name="margin_percent"/>
                <field name="sap_synced" widget="boolean_toggle"/>
                <field name="sap_last_sync"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Margin Form View -->
    <record id="view_sofa_margin_form" model="ir.ui.view">
        <field name="name">sofa.margin.form</field>
        <field name="model">sofa.margin</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="series_id"/>
                            <field name="article_group"/>
                            <field name="margin_percent"/>
                        </group>
                        <group>
                            <field name="sap_synced"/>
                            <field name="sap_last_sync"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_sofa_margin" model="ir.actions.act_window">
        <field name="name">Margins</field>
        <field name="res_model">sofa.margin</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
