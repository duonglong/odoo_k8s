<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Series Tree View -->
    <record id="view_sofa_series_tree" model="ir.ui.view">
        <field name="name">sofa.series.tree</field>
        <field name="model">sofa.series</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="full_name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Series Form View -->
    <record id="view_sofa_series_form" model="ir.ui.view">
        <field name="name">sofa.series.form</field>
        <field name="model">sofa.series</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="full_name"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Styles">
                            <field name="style_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="active" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Series Action -->
    <record id="action_sofa_series" model="ir.actions.act_window">
        <field name="name">Series</field>
        <field name="res_model">sofa.series</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Style Action -->
    <record id="action_sofa_style" model="ir.actions.act_window">
        <field name="name">Styles</field>
        <field name="res_model">sofa.style</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
