<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Main Menu -->
    <menuitem id="menu_sofa_pricing_root"
              name="Sofa Pricing"
              sequence="10"
              web_icon="htl_sofa_pricing,static/description/icon.png"/>

    <!-- Quotes Menu -->
    <menuitem id="menu_sofa_pricing_quotes"
              name="Quotes"
              parent="menu_sofa_pricing_root"
              sequence="10"/>

    <menuitem id="menu_sofa_price_quote"
              name="Price Quotes"
              parent="menu_sofa_pricing_quotes"
              action="action_sofa_price_quote"
              sequence="10"/>

    <!-- Configuration Menu -->
    <menuitem id="menu_sofa_pricing_configuration"
              name="Configuration"
              parent="menu_sofa_pricing_root"
              sequence="20"/>

    <menuitem id="menu_sofa_component_template"
              name="Component Templates"
              parent="menu_sofa_pricing_configuration"
              action="action_sofa_component_template"
              sequence="10"/>

    <menuitem id="menu_sofa_component_type"
              name="Component Types"
              parent="menu_sofa_pricing_configuration"
              action="action_sofa_component_type"
              sequence="20"/>

    <menuitem id="menu_sofa_option_type"
              name="Option Types"
              parent="menu_sofa_pricing_configuration"
              action="action_sofa_option_type"
