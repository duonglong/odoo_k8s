    <menuitem id="menu_sofa_pricing_master_data"
              name="Master Data"
              parent="menu_sofa_pricing_root"
              sequence="30"/>

    <menuitem id="menu_sofa_series"
              name="Series"
              parent="menu_sofa_pricing_master_data"
              action="action_sofa_series"
              sequence="10"/>

    <menuitem id="menu_sofa_style"
              name="Styles"
              parent="menu_sofa_pricing_master_data"
              action="action_sofa_style"
              sequence="20"/>

    <menuitem id="menu_sofa_article_category"
              name="Article Categories"
              parent="menu_sofa_pricing_master_data"
              action="action_sofa_article_category"
              sequence="30"/>

    <menuitem id="menu_sofa_article"
              name="Articles"
              parent="menu_sofa_pricing_master_data"
              action="action_sofa_article"
              sequence="40"/>

    <menuitem id="menu_sofa_margin"
              name="Margins"
              parent="menu_sofa_pricing_master_data"
              action="action_sofa_margin"
              sequence="50"/>
